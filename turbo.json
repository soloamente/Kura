{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", ".next/**"],
			"env": [
				"DATABASE_URL",
				"BETTER_AUTH_SECRET",
				"BETTER_AUTH_URL",
				"CORS_ORIGIN",
				"GOOGLE_GENERATIVE_AI_API_KEY",
				"TRIGGER_SECRET_KEY",
				"R2_ACCOUNT_ID",
				"R2_ACCESS_KEY_ID",
				"R2_SECRET_ACCESS_KEY",
				"R2_BUCKET_NAME",
				"R2_PUBLIC_URL",
				"NEXT_PUBLIC_SERVER_URL",
				"WXT_PUBLIC_API_URL",
				"WXT_PUBLIC_WEB_URL"
			]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"db:push": {
			"cache": false
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false,
			"persistent": true
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		},
		"db:pull": {
			"cache": false,
			"persistent": true
		}
	}
}
