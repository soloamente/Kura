{
	"name": "server",
	"type": "module",
	"main": "dist/main.mjs",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/main.ts",
		"start": "bun run dist/main.mjs"
	},
	"dependencies": {
		"@Kura/auth": "workspace:*",
		"@Kura/db": "workspace:*",
		"@Kura/env": "workspace:*",
		"@ai-sdk/devtools": "^0.0.2",
		"@ai-sdk/google": "^3.0.1",
		"@aws-sdk/client-s3": "^3.1005.0",
		"@elysiajs/cors": "^1.4.1",
		"@trigger.dev/sdk": "4.4.3",
		"ai": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"elysia": "^1.4.21",
		"import-in-the-middle": "^3.0.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@Kura/config": "workspace:*",
		"@trigger.dev/build": "4.4.3",
		"@types/bun": "catalog:",
		"tsdown": "^0.16.5",
		"typescript": "^5"
	}
}
